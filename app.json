{
  "expo": {
    "name": "Erebus Portal",
    "slug": "erebus-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-insta.png",
    "scheme": "erebusmobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cerebralproductions.erebus"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b0b0c",
        "foregroundImage": "./assets/images/logo-insta.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.cerebralproductions.erebus"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-insta.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-insta.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0b0b0c",
          "dark": {
            "backgroundColor": "#0b0b0c"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}